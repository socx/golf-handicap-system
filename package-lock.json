{
  "name": "golf-handicap-system",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "golf-handicap-system",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=20 <21"
      }
    },
    "apps/api": {
      "name": "@ghs/api",
      "version": "0.1.0"
    },
