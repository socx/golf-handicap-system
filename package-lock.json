    },
    "apps/worker": {
      "name": "@ghs/worker",
      "version": "0.1.0"
    },
    "node_modules/@ghs/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@ghs/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/@ghs/worker": {
      "resolved": "apps/worker",
      "link": true
