{
  "name": "golf-handicap-system",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "check:versions": "node scripts/check-versions.js"
  },
  "engines": {
    "node": ">=20 <21"
  }
}
