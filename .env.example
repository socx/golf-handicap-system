# Golf Handicap System - Environment Template
# Copy to .env in the repository root.

# Runtime
NODE_ENV=development

# API
API_PORT=3005
JWT_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_EXPIRES_IN=1h
APP_URL=http://localhost:5175
SELF_REGISTRATION_ENABLED=false
ACCOUNT_ACTIVATION_TOKEN_EXPIRY_HOURS=24

# Database
DATABASE_URL=postgresql://database_user:SomeSecurePassword@localhost:5432/database_name

# Redis
REDIS_URL=redis://localhost:6379
CACHE_TTL_DASHBOARD_SECONDS=60
CACHE_TTL_LEADERBOARD_SECONDS=45
CACHE_TTL_SETTINGS_SECONDS=300
# Optional: required for POST /api/cache/invalidate when set
CACHE_ADMIN_KEY=

# Web
WEB_PORT=5175
VITE_API_URL=http://localhost:3005/api
VITE_SELF_REGISTRATION_ENABLED=false

# ── SMTP ───────────────────────────────────────────
# Email transport strategy:
# - development: defaults to mailpit
# - production: defaults to smtp
# Override with EMAIL_TRANSPORT=mailpit|smtp|sendgrid|ses
EMAIL_TRANSPORT=mailpit
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# SendGrid (required when EMAIL_TRANSPORT=sendgrid)
SENDGRID_API_KEY=

# SES (supported via SMTP credentials; region retained for compatibility)
SES_REGION=eu-west-2

# Password reset token expiry (minutes)
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=60
